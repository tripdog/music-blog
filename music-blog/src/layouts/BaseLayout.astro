---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  image?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  image,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
  <script is:inline>
  (function() {
    var theme = localStorage.getItem('sn-theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
  })();
  </script>
    <BaseHead title={title} description={description} canonicalURL={canonicalURL} image={image} />
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
