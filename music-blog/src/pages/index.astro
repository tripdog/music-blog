---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterSection from '../components/NewsletterSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SkullMark from '../components/SkullMark.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const gridPosts = allPosts.filter((p) => p.id !== featured?.id).slice(0, 3);

const featuredDate = featured?.data.pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).toUpperCase();

const GENRES = ['PUNK', 'REGGAE', 'METAL', 'GOTH', 'OTHER'];
---

<BaseLayout>
  <Masthead />

  <main>
    <!-- Hero -->
    <section class="hero" id="whats-here">
      <div class="hero__inner">
        <h1 class="hero__wordmark" transition:name="site-logo">
          <span>signal</span><span class="hero__slash">/</span><span>noise</span>
        </h1>
        <div class="hero__rule"></div>
        <div class="hero__sub">
          <p class="hero__tagline">
            Records, reviews, and rants. From someone whose vinyl collection has opinions about you back.
          </p>
          <div class="hero__genres">
            <p class="hero__genres-label">WHAT'S HERE</p>
            <div class="hero__genres-row">
              {GENRES.map((g) => (
                <a href={`/category/${g.toLowerCase()}`} class="genre-pill">{g}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest section -->
    <section class="latest" id="latest">
      <div class="latest__inner">
        <h2 class="latest__heading">latest.</h2>
        <div class="latest__rule"></div>

        <!-- Featured post -->
        {featured && (
          <article class="featured-post">
            <p class="featured-post__meta">
              FEATURED
              {featured.data.category && ` · ${featured.data.category.toUpperCase()}`}
              {` · ${featuredDate}`}
            </p>
            <h3 class="featured-post__title">
              <a href={`/blog/${featured.id}`}>{featured.data.title}</a>
            </h3>
            <p class="featured-post__excerpt">{featured.data.description}</p>
          </article>
        )}

        <!-- Post card grid -->
        {gridPosts.length > 0 && (
          <div class="post-grid">
            {gridPosts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                category={post.data.category ?? 'Post'}
                date={post.data.pubDate}
                slug={post.id}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <NewsletterSection />
  <SiteFooter />
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    background: var(--color-bg);
  }

  .hero__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 40px 80px 60px;
  }

  .hero__wordmark {
    font-size: clamp(80px, 12.5vw, 180px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--color-ink);
    margin: 0 0 48px;
    white-space: nowrap;
  }

  .hero__slash {
    color: #ff4d2e;
  }

  .hero__rule {
    height: 8px;
    background: var(--color-ink);
    margin-bottom: 32px;
  }

  .hero__sub {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .hero__tagline {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-ink);
    max-width: 600px;
    margin: 0;
  }

  .hero__genres {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hero__genres-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin: 0;
  }

  .hero__genres-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .genre-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
    padding: 0.4rem 1rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-align: center;
    color: var(--color-ink);
    background: var(--color-bg);
    border: 2px solid var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }

  .genre-pill + .genre-pill {
    margin-left: -2px;
  }

  .genre-pill:hover {
    background: var(--color-orange);
    color: #0a0a0a;
    border-color: var(--color-orange);
  }

  /* ---- Latest ---- */
  .latest {
    background: var(--color-bg);
  }

  .latest__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 80px 80px;
  }

  .latest__heading {
    font-size: 64px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 12px;
  }

  .latest__rule {
    height: 4px;
    background: var(--color-ink);
    margin-bottom: 32px;
  }

  /* ---- Featured post ---- */
  .featured-post {
    background: #0a0a0a;
    padding: 40px 48px;
    margin-bottom: 32px;
  }

  .featured-post__meta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: #ff4d2e;
    margin: 0 0 16px;
  }

  .featured-post__title {
    font-size: clamp(32px, 3.9vw, 56px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #f5f5f0;
    margin: 0 0 28px;
  }

  .featured-post__title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-post__title a:hover {
    color: #ff4d2e;
  }

  .featured-post__excerpt {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.4;
    color: #f5f5f0;
    opacity: 0.85;
    max-width: 900px;
    margin: 0;
  }

  /* ---- Post grid ---- */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ---- Responsive ---- */

  /* Tablet (640–1023px) */
  @media (min-width: 640px) and (max-width: 1023px) {
    .hero__inner,
    .latest__inner {
      padding-left: 40px;
      padding-right: 40px;
    }

    .hero__wordmark {
      font-size: clamp(5rem, 12vw, 10rem);
      white-space: normal;
    }

    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile (≤639px) */
  @media (max-width: 639px) {
    .hero__inner,
    .latest__inner {
      padding-left: 24px;
      padding-right: 24px;
    }

    .hero__wordmark {
      font-size: clamp(3rem, 15vw, 7rem);
      white-space: normal;
    }

    .hero__sub {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero__tagline {
      font-size: clamp(1rem, 4vw, 1.4rem);
    }

    .latest__heading {
      font-size: clamp(2rem, 8vw, 4rem);
    }

    .featured-post {
      padding: 28px 24px;
    }

    .post-grid {
      grid-template-columns: 1fr;
      margin: 0;
    }
  }
</style>
