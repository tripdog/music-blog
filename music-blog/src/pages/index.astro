---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Signal &amp; Noise</h1>
			<p>
				Music writing for people who take it seriously (but not themselves). This is a blog about
				records, artists, and sounds worth obsessing over, filtered through ears that have spent
				too long in the goth section, the alternative racks, and everywhere in between.
			</p>
			<p>
				Every genre gets a fair hearing here. Post-punk sits next to soul. Ambient shares shelf
				space with metal. If it's interesting, it's fair game.
			</p>
			<p>
				Pull up a chair. Turn it up.
			</p>
		</main>
		<Footer />
	</body>
</html>
