---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout title="About — Signal & Noise" description="About Signal & Noise, a music blog by Tom Phillips.">
  <Masthead />
  <main class="about">
    <div class="about__inner prose">
      <h1>About.</h1>
      <p>
        Signal &amp; Noise is a music blog by Tom Phillips, written from San Diego, CA. The premise is
        that there's still original music being made in genres people declared dead. Most algorithms
        can't find it. This is a place where it gets written about.
      </p>
      <p>
        The writing covers records (new and old), live shows, and whatever else seems worth the words.
        The categories loosely follow the genres: punk, reggae, metal, goth, and a catch-all for
        everything else. The bias is toward things that hold up over time and bands that never got
        their fair hearing.
      </p>
      <p>
        Published every two weeks or so. No ads, no sponsored posts, no algorithm chasing.
        If something's good it gets written about. If it isn't, it doesn't.
      </p>
      <hr />
      <p class="about__meta">Tom Phillips. San Diego. Est. 2026.</p>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .about {
    background: var(--color-bg);
    min-height: 60vh;
  }

  .about__inner {
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .about__inner h1 {
    font-size: 96px;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.05em;
    margin: 0 0 48px;
  }

  .about__meta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
</style>
