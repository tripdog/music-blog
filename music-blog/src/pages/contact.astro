---
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';

const canonicalURL = new URL('/contact', Astro.site).href;
---

<BaseLayout
  title="Contact — Signal & Noise"
  description="Send a message, argue about a review, or just say hello. Find Signal & Noise on Mastodon, Bluesky, Instagram, and more."
  canonicalURL={canonicalURL}
>
  <Masthead />

  <div class="contact-orange-rule"></div>

  <main class="contact">

    <!-- Hero -->
    <section class="contact-hero">
      <div class="contact__inner">
        <p class="contact__eyebrow">CONTACT</p>
        <h1 class="contact-hero__heading">
          Got something to say? Good<span style="color: var(--color-orange)">.</span>
        </h1>
      </div>
    </section>

    <!-- Ink rule (constrained to content width) -->
    <div class="contact__inner">
      <div class="contact-ink-rule"></div>
    </div>

    <!-- Two-column body -->
    <section class="contact-body">
      <div class="contact__inner contact-body__grid">

        <!-- Form column -->
        <div class="contact-form-col">
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="contact-form"
          >
            <input type="hidden" name="access_key" value="e7711767-401b-463e-affe-1cc0b1275f1f" />
            <input type="hidden" name="subject" value="Signal & Noise — Contact Form" />
            <input type="hidden" name="to" value="tom@atomicpx.com" />

            <div class="contact-form__row">
              <div class="contact-form__field">
                <label for="first-name" class="contact-form__label">First Name</label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  class="contact-form__input"
                  required
                  autocomplete="given-name"
                />
              </div>
              <div class="contact-form__field">
                <label for="last-name" class="contact-form__label">Last Name</label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  class="contact-form__input"
                  required
                  autocomplete="family-name"
                />
              </div>
            </div>

            <div class="contact-form__field">
              <label for="email" class="contact-form__label">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                class="contact-form__input"
                required
                autocomplete="email"
              />
            </div>

            <div class="contact-form__field">
              <label for="message" class="contact-form__label">Comments / Questions</label>
              <textarea
                id="message"
                name="message"
                class="contact-form__textarea"
                rows="8"
                required
              ></textarea>
            </div>

            <button type="submit" class="contact-form__submit">SEND IT →</button>
          </form>
        </div>

        <!-- Social column -->
        <div class="contact-social-col">
          <p class="contact__eyebrow">FIND ME HERE</p>
          <ul class="contact-social__list">

            <li>
              <a href="https://www.facebook.com/dharma.mind.94" class="contact-social__link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            </li>

            <li>
              <a href="https://www.instagram.com/atomicpx_com/" class="contact-social__link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            </li>

            <li>
              <a href="https://github.com/tripdog/" class="contact-social__link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
              </a>
            </li>

            <li>
              <a href="https://indieweb.social/@atomic" class="contact-social__link" target="_blank" rel="noopener noreferrer" aria-label="Mastodon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/>
                </svg>
              </a>
            </li>

            <li>
              <a href="https://bsky.app/profile/atomicpx.com" class="contact-social__link" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                <svg width="22" height="22" viewBox="0 0 600 530" fill="currentColor" aria-hidden="true">
                  <path d="m135.72 44.03c66.496 49.921 138.02 151.14 164.28 205.46 26.262-54.316 97.782-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z"/>
                </svg>
              </a>
            </li>

          </ul>
        </div>

      </div>
    </section>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .contact-orange-rule {
    height: 8px;
    background: var(--color-orange);
    width: 100%;
  }

  .contact {
    background: var(--color-bg);
  }

  .contact__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 80px;
    padding-right: 80px;
  }

  .contact__eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  /* ---- Hero ---- */
  .contact-hero {
    padding-top: 64px;
    padding-bottom: 40px;
  }

  .contact-hero__heading {
    font-size: clamp(56px, 9vw, 96px);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: var(--color-ink);
  }

  /* ---- Ink rule ---- */
  .contact-ink-rule {
    height: 8px;
    background: var(--color-ink);
    margin-bottom: 56px;
  }

  /* ---- Body ---- */
  .contact-body {
    padding-bottom: 96px;
  }

  .contact-body__grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 80px;
    align-items: start;
  }

  /* ---- Form ---- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-form__label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .contact-form__input,
  .contact-form__textarea {
    font-family: inherit;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-ink);
    border-radius: 2px;
    padding: 12px 14px;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder {
    color: var(--color-muted);
    opacity: 0.7;
  }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    border-color: var(--color-orange);
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 180px;
    line-height: 1.5;
  }

  .contact-form__submit {
    align-self: flex-start;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-bg);
    background: var(--color-orange);
    border: none;
    border-radius: 2px;
    padding: 14px 28px;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .contact-form__submit:hover {
    opacity: 0.85;
  }

  /* ---- Social column ---- */
  .contact-social-col {
    padding-top: 4px;
  }

  .contact-social__list {
    display: flex;
    flex-direction: column;
    gap: 28px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-social__link {
    display: flex;
    align-items: center;
    color: var(--color-ink);
    transition: color 0.15s;
    text-decoration: none;
  }

  .contact-social__link:hover {
    color: var(--color-orange);
  }

  /* ---- Tablet (640–1023px) ---- */
  @media (min-width: 640px) and (max-width: 1023px) {
    .contact__inner {
      padding-left: 40px;
      padding-right: 40px;
    }

    .contact-body__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .contact-social__list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 28px;
    }
  }

  /* ---- Mobile (≤639px) ---- */
  @media (max-width: 639px) {
    .contact__inner {
      padding-left: 24px;
      padding-right: 24px;
    }

    .contact-body__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .contact-form__row {
      grid-template-columns: 1fr;
    }

    .contact-body {
      padding-bottom: 56px;
    }

    .contact-social__list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 24px;
    }
  }
</style>
