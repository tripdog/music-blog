---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Masthead from '../../components/Masthead.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: entry,
  }));
}

type Props = CollectionEntry<'blog'>;

const entry = Astro.props;
const { Content } = await render(entry);

const wordCount = entry.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));

const formattedDate = entry.data.pubDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).toUpperCase();

const lede = entry.data.lede ?? entry.data.description;
const albumArt = entry.data.albumArt;
const heroImage = entry.data.heroImage;
const rating = entry.data.rating;
const verdict = entry.data.verdict;
const category = entry.data.category;

const floorRating = rating !== undefined ? Math.floor(rating) : 0;
const fracRating = rating !== undefined ? rating % 1 : 0;

// Skull sizes from Figma measurements: teaser=24px+5px gap, verdict=38px+8px gap
const SKULL_HERO_W = 24;
const SKULL_HERO_H = Math.round(SKULL_HERO_W * 144 / 110);
const SKULL_VDT_W = 38;
const SKULL_VDT_H = Math.round(SKULL_VDT_W * 144 / 110);

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = entry.data.heroImage ?? '/og-image.jpg';
---

<BaseLayout
  title={`${entry.data.title} — Signal & Noise`}
  description={entry.data.description}
  canonicalURL={canonicalURL}
  image={ogImage}
>
  <Masthead />

  {heroImage && (
    <div class="post-hero-img">
      <img src={heroImage} alt="" class="post-hero-img__img" onerror="this.closest('.post-hero-img').remove()" />
    </div>
  )}

  <main class="post-page">
    <nav class="post-breadcrumb" aria-label="Breadcrumb">
      <a href="/">SIGNAL &amp; NOISE</a>
      {category && (
        <>
          <span class="post-breadcrumb__sep">/</span>
          <span>{category.toUpperCase()}</span>
        </>
      )}
    </nav>

    {category && (
      <p class="post-category">{category.toUpperCase()}</p>
    )}

    <h1 class="post-title" transition:name={"post-title-" + entry.id}>{entry.data.title}</h1>

    <p class="post-lede">{lede}</p>

    <div class="post-rule"></div>

    <div class="post-byline">
      <span class="post-byline__text">
        BY TOM PHILLIPS &middot; <span transition:name={"post-date-" + entry.id}>{formattedDate}</span> &middot; {readTime} MIN READ
      </span>
      <button class="post-byline__share" id="share-btn" type="button">SHARE / COPY LINK</button>
    </div>

    {rating !== undefined && (
      <div class="post-teaser-skulls">
        {Array.from({ length: 5 }, (_, i) => {
            const isFull = i < floorRating;
            const isEmpty = !isFull;
            const wrapWidth = SKULL_HERO_W;
            return (
              <span class="skull-clip" style={`width:${wrapWidth}px`}>
              <img
                src="/skull-bone.svg"
                class="skull-icon"
                width={SKULL_HERO_W}
                height={SKULL_HERO_H}
                alt=""
                style={isEmpty ? 'opacity:0.15' : ''}
              />
            </span>
          );
        })}
        <span class="post-teaser-skulls__score">{rating.toFixed(2)} / 5</span>
      </div>
    )}

    {albumArt && (
      <img
        src={albumArt}
        alt=""
        class="post-album-art"
        width="200"
        height="200"
        onerror="this.remove()"
      />
    )}

    <div class="post-prose">
      <Content />
    </div>

    <div class="post-author">
      <p class="post-author__slash">/</p>
      <div class="post-author__rule"></div>
      <p class="post-author__label">WRITTEN BY</p>
      <p class="post-author__name">Tom Phillips</p>
      <p class="post-author__bio">
        Writes about music from San Diego. Has been collecting records since before that was a personality trait. Practices guitar daily and remains genuinely bad at it.
      </p>
    </div>

    {rating !== undefined && (
      <div class="post-verdict">
        <div class="post-verdict__rule"></div>
        <p class="post-verdict__label">FINAL VERDICT</p>
        <div class="post-verdict__skulls">
          {Array.from({ length: 5 }, (_, i) => {
            const isFull = i < floorRating;
            const isEmpty = !isFull;
            const wrapWidth = SKULL_VDT_W;
            return (
              <span class="skull-clip" style={`width:${wrapWidth}px`}>
                <img
                  src="/skull-bone.svg"
                  class="skull-icon"
                  width={SKULL_VDT_W}
                  height={SKULL_VDT_H}
                  alt=""
                  style={isEmpty ? 'opacity:0.15' : ''}
                />
              </span>
            );
          })}
          <span class="post-verdict__score">{rating.toFixed(2)} / 5</span>
        </div>
        {verdict && <p class="post-verdict__blurb">{verdict}</p>}
      </div>
    )}
  </main>

  {related.length > 0 && (
    <section class="keep-reading">
      <h2 class="keep-reading__heading">keep reading.</h2>
      <div class="keep-reading__rule"></div>
      <div class="keep-reading__grid">
        {related.map((post) => {
          const postDate = post.data.pubDate.toLocaleDateString('en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
          }).toUpperCase();
          return (
            <a href={`/blog/${post.id}`} class="krc">
              <div class="krc__bar"></div>
              <div class="krc__body">
                <p class="krc__meta">
                  {post.data.category ? post.data.category.toUpperCase() : 'POST'} &middot; {postDate}
                </p>
                <h3 class="krc__title">{post.data.title}</h3>
                <p class="krc__excerpt">{post.data.description}</p>
                <span class="krc__cta">READ &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <SiteFooter />
</BaseLayout>

<script>
  function initShareBtn() {
    document.getElementById('share-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const btn = document.getElementById('share-btn') as HTMLButtonElement;
        if (btn) {
          const orig = btn.textContent;
          btn.textContent = 'COPIED!';
          setTimeout(() => { btn.textContent = orig; }, 2000);
        }
      });
    });
  }
  initShareBtn();
  document.addEventListener('astro:page-load', initShareBtn);
</script>

<style>
  /* ── Hero image ── */
  .post-hero-img {
    width: 100%;
    height: 720px;
    overflow: hidden;
  }

  .post-hero-img__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Page content wrapper ── */
  .post-page {
    background: var(--color-bg);
    padding: 0 80px 80px;
  }

  /* ── Breadcrumb ── */
  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: #5a5a5a;
    margin-top: 40px;
  }

  .post-breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-breadcrumb a:hover {
    color: #ff4d2e;
  }

  .post-breadcrumb__sep {
    opacity: 0.5;
  }

  /* ── Category label ── */
  .post-category {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.26em;
    color: #ff4d2e;
    margin-top: 8px;
  }

  /* ── Title ── */
  .post-title {
    font-size: clamp(2.5rem, 6.1vw, 5.5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    max-width: 1280px;
    margin-top: 16px;
  }

  /* ── Lede ── */
  .post-lede {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-ink);
    max-width: 960px;
    margin-top: 16px;
  }

  /* ── Horizontal rule ── */
  .post-rule {
    height: 4px;
    background: var(--color-ink);
    margin-top: 40px;
  }

  /* ── Byline ── */
  .post-byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 16px;
  }

  .post-byline__text {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-muted);
  }

  .post-byline__share {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .post-byline__share:hover {
    color: #ff4d2e;
  }

  /* ── Skull teaser ── */
  .post-teaser-skulls {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 16px;
  }

  .post-teaser-skulls__score {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: #ff4d2e;
    margin-left: 8px;
  }

  /* ── Skull shared styles ── */
  .skull-clip {
    display: inline-block;
    overflow: hidden;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .skull-icon {
    display: block;
    filter: invert(1);
  }

  :global([data-theme="dark"]) .skull-icon {
    filter: invert(0);
  }

  /* ── Body prose ── */
  .post-prose {
    max-width: 720px;
    margin-top: 48px;
    font-size: 19px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-ink);
  }

  .post-prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .post-prose > :global(*) {
    margin-bottom: 1.5rem;
  }

  .post-prose > :global(*:last-child) {
    margin-bottom: 0;
  }

  .post-prose :global(h2) {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-prose :global(h3) {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-prose :global(blockquote) {
    margin: 2.5rem 0;
    max-width: 1000px;
    padding: 0;
    border: none;
  }

  .post-prose :global(blockquote::before) {
    content: '';
    display: block;
    width: 80px;
    height: 8px;
    background: #ff4d2e;
    margin-bottom: 20px;
  }

  .post-prose :global(blockquote p) {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-bottom: 0;
  }

  .post-prose :global(a) {
    color: #ff4d2e;
    text-decoration: none;
  }

  .post-prose :global(a:hover) {
    text-decoration: underline;
  }

  .post-prose :global(strong) {
    font-weight: 700;
  }

  /* ── Author bio ── */
  .post-author {
    max-width: 720px;
    margin-top: 72px;
    clear: both;
  }

  .post-author__slash {
    font-size: 36px;
    font-weight: 900;
    line-height: 1;
    color: #ff4d2e;
    margin-bottom: 12px;
  }

  .post-author__rule {
    height: 4px;
    background: var(--color-ink);
    margin-bottom: 24px;
  }

  .post-author__label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .post-author__name {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 12px;
  }

  .post-author__bio {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-ink);
    opacity: 0.8;
  }

  /* ── Album art (top of article) ── */
  .post-album-art {
    float: right;
    width: 200px;
    height: 200px;
    object-fit: cover;
    margin-left: 24px;
    margin-bottom: 16px;
    margin-top: 4px;
  }

  /* ── Final verdict ── */
  .post-verdict {
    max-width: 720px;
    margin-top: 56px;
  }

  .post-verdict__rule {
    height: 1px;
    background: var(--color-ink);
    opacity: 0.12;
    margin-bottom: 40px;
  }

  .post-verdict__label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: #ff4d2e;
    margin-bottom: 16px;
  }

  .post-verdict__skulls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .post-verdict__score {
    font-size: 22px;
    font-weight: 700;
    color: #ff4d2e;
    margin-left: 8px;
  }

  .post-verdict__blurb {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-muted);
  }

  /* ── Keep reading ── */
  .keep-reading {
    background: var(--color-bg);
    padding: 64px 80px 80px;
  }

  .keep-reading__heading {
    font-size: 48px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: 16px;
  }

  .keep-reading__rule {
    height: 4px;
    background: var(--color-ink);
    margin-bottom: 32px;
  }

  .keep-reading__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }

  .krc {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-ink);
    text-decoration: none;
    color: var(--color-ink);
    min-height: 320px;
    transition: background 0.15s;
  }

  .krc:hover {
    background: var(--color-surface);
  }

  .krc + .krc {
    border-left: none;
  }

  .krc__bar {
    height: 8px;
    background: var(--color-ink);
    flex-shrink: 0;
  }

  .krc__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 27px;
  }

  .krc__meta {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.198em;
    color: #ff4d2e;
    margin-bottom: 12px;
  }

  .krc__title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 12px;
  }

  .krc__excerpt {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-muted);
    flex: 1;
  }

  .krc__cta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-ink);
    padding-top: 24px;
    display: block;
  }

  /* ── Tablet (640–1023px) ── */
  @media (min-width: 640px) and (max-width: 1023px) {
    .post-hero-img {
      height: 480px;
    }

    .post-page {
      padding: 0 40px 64px;
    }

    .keep-reading {
      padding: 48px 40px 64px;
    }
  }

  /* ── Mobile (≤639px) ── */
  @media (max-width: 639px) {
    .post-hero-img {
      height: 240px;
    }

    .post-page {
      padding: 0 24px 64px;
    }

    .post-title {
      font-size: clamp(2rem, 8vw, 3.5rem);
    }

    .post-lede {
      font-size: 18px;
    }

    .post-byline {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .post-prose {
      font-size: 17px;
      margin-top: 32px;
    }

    .post-album-art {
      float: none;
      width: 100%;
      height: 200px;
      margin-left: 0;
      margin-bottom: 16px;
    }

    .post-prose :global(blockquote p) {
      font-size: clamp(1.25rem, 5vw, 2.25rem);
    }

    .post-author,
    .post-verdict {
      max-width: 100%;
    }

    .keep-reading {
      padding: 48px 24px 64px;
    }

    .keep-reading__heading {
      font-size: 36px;
    }

    .keep-reading__grid {
      grid-template-columns: 1fr;
    }

    .krc + .krc {
      border-left: 1px solid var(--color-ink);
      border-top: none;
    }

    .krc__title {
      font-size: 24px;
    }
  }
</style>
