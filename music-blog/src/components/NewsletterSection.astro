---
---

<section class="newsletter">
  <div class="newsletter__inner">
    <div class="newsletter__copy">
      <h2 class="newsletter__heading">subscribe.</h2>
      <p class="newsletter__body">Every two weeks. New writing, a few recommendations, no algorithms.</p>
    </div>
    <form class="newsletter__form">
      <input
        class="newsletter__input"
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        aria-label="Email address"
      />
      <button class="newsletter__btn" type="submit">SUBSCRIBE &rarr;</button>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector('.newsletter__form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    console.log('Subscribe clicked — MailChimp integration coming');
  });
</script>

<style>
  .newsletter {
    background: #ff4d2e;
    overflow: hidden;
    box-sizing: border-box;
    max-width: 100%;
  }

  .newsletter__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 48px 80px;
    display: flex;
    align-items: center;
    gap: 80px;
    box-sizing: border-box;
  }

  .newsletter__copy {
    flex: 0 0 auto;
    max-width: 600px;
    width: 100%;
  }

  .newsletter__heading {
    font-size: 56px;
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #0a0a0a;
    margin-bottom: 16px;
  }

  .newsletter__body {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.4;
    color: #0a0a0a;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .newsletter__form {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: auto;
    flex-shrink: 0;
  }

  .newsletter__input {
    width: 380px;
    height: 48px;
    padding: 0 16px;
    font-size: 15px;
    font-weight: 400;
    color: #5a5a5a;
    background: #ededed;
    border: 2px solid #0a0a0a;
    border-right: none;
    outline: none;
    font-family: inherit;
  }

  .newsletter__input::placeholder {
    color: #5a5a5a;
  }

  .newsletter__input:focus {
    background: #fff;
  }

  .newsletter__btn {
    height: 48px;
    padding: 0 24px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: #f5f5f0;
    background: #0a0a0a;
    border: 2px solid #0a0a0a;
    white-space: nowrap;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }

  .newsletter__btn:hover {
    background: #ff4d2e;
    color: #0a0a0a;
    border-color: #0a0a0a;
  }

  /* Tablet (640–1023px) */
  @media (min-width: 640px) and (max-width: 1023px) {
    .newsletter__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
      padding: 48px 40px;
    }

    .newsletter__form {
      margin-left: 0;
    }
  }

  /* Mobile (≤639px) */
  @media (max-width: 639px) {
    .newsletter__inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 40px 24px;
      gap: 32px;
    }

    .newsletter__copy {
      width: 100%;
      max-width: 100%;
    }

    .newsletter__heading {
      font-size: 40px;
      width: 100%;
    }

    .newsletter__body {
      width: 100%;
      padding-right: 0;
    }

    .newsletter__form {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      margin-left: 0;
    }

    .newsletter__input {
      width: 100%;
      border-right: 2px solid #0a0a0a;
      border-bottom: none;
    }

    .newsletter__btn {
      width: 100%;
      border-top: none;
    }
  }
</style>
