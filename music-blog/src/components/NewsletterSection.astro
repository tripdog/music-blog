<section class="newsletter">
  <div class="newsletter__inner">
    <div class="newsletter__copy">
      <h2 class="newsletter__heading">subscribe.</h2>
      <p class="newsletter__body">Every two weeks. New writing, a few recommendations, no algorithms.</p>
    </div>
    <div class="newsletter__embed">
      <script is:inline async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="59fb7fce-ddf6-46b9-a2d4-90d50108adfc"></script>
      <script is:inline type="text/javascript" async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: #ff4d2e;
    overflow: hidden;
    box-sizing: border-box;
    max-width: 100%;
  }

  .newsletter__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 48px 80px;
    display: flex;
    align-items: center;
    gap: 80px;
    box-sizing: border-box;
  }

  .newsletter__copy {
    flex: 0 0 auto;
    max-width: 600px;
    width: 100%;
  }

  .newsletter__heading {
    font-size: 56px;
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #0a0a0a;
    margin-bottom: 16px;
  }

  .newsletter__body {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.4;
    color: #0a0a0a;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .newsletter__embed {
    margin-left: auto;
    flex-shrink: 0;
    min-width: 380px;
    max-width: 480px;
  }

  /* Nudge Beehiiv's injected widget to fit the orange section */
  .newsletter__embed :global(iframe),
  .newsletter__embed :global(.beehiiv-subscribe-form) {
    max-width: 100% !important;
    background: transparent !important;
  }

  /* Tablet (640–1023px) */
  @media (min-width: 640px) and (max-width: 1023px) {
    .newsletter__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
      padding: 48px 40px;
    }

    .newsletter__embed {
      margin-left: 0;
      width: 100%;
      max-width: 100%;
    }
  }

  /* Mobile (≤639px) */
  @media (max-width: 639px) {
    .newsletter__inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 40px 24px;
      gap: 32px;
    }

    .newsletter__copy {
      width: 100%;
      max-width: 100%;
    }

    .newsletter__heading {
      font-size: 40px;
      width: 100%;
    }

    .newsletter__body {
      width: 100%;
      padding-right: 0;
    }

    .newsletter__embed {
      width: 100%;
      min-width: 0;
      max-width: 100%;
      margin-left: 0;
    }
  }
</style>
