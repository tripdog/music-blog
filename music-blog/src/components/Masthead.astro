---
import SkullMark from './SkullMark.astro';
---

<header class="masthead">
  <div class="masthead__inner">
    <a href="/" class="masthead__brand" aria-label="Signal and Noise home">
      <SkullMark variant="bone" size={24} />
      <span class="masthead__wordmark">SIGNAL &amp; NOISE</span>
    </a>

    <nav class="masthead__nav" aria-label="Primary navigation">
      <a href="/#latest">LATEST</a>
      <a href="/#whats-here">GENRES</a>
      <a href="/about">ABOUT</a>
    </nav>

    <div class="masthead__actions">
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle light and dark mode"
        title="Toggle theme"
      >
        <span class="theme-toggle__icon theme-toggle__icon--light" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.5 12.5A7.5 7.5 0 1 1 7.5 2.5a5.5 5.5 0 0 0 10 10z"/>
          </svg>
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="10" cy="10" r="4"/>
            <line x1="10" y1="1" x2="10" y2="3"/>
            <line x1="10" y1="17" x2="10" y2="19"/>
            <line x1="1" y1="10" x2="3" y2="10"/>
            <line x1="17" y1="10" x2="19" y2="10"/>
            <line x1="3.22" y1="3.22" x2="4.64" y2="4.64"/>
            <line x1="15.36" y1="15.36" x2="16.78" y2="16.78"/>
            <line x1="3.22" y1="16.78" x2="4.64" y2="15.36"/>
            <line x1="15.36" y1="4.64" x2="16.78" y2="3.22"/>
          </svg>
        </span>
      </button>

      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="2" y1="6" x2="20" y2="6"/>
          <line x1="2" y1="11" x2="20" y2="11"/>
          <line x1="2" y1="16" x2="20" y2="16"/>
        </svg>
      </button>
    </div>
  </div>

  <nav class="masthead__mobile-nav" id="nav-menu" aria-label="Mobile navigation">
    <a href="/#latest">LATEST</a>
    <a href="/#whats-here">GENRES</a>
    <a href="/about">ABOUT</a>
  </nav>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle') as HTMLButtonElement;
  const navToggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const navMenu = document.getElementById('nav-menu') as HTMLElement;

  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('sn-theme', next);
  });

  navToggle?.addEventListener('click', () => {
    const isOpen = navMenu.classList.toggle('nav-open');
    navToggle.setAttribute('aria-expanded', String(isOpen));
  });

  navMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      navMenu.classList.remove('nav-open');
      navToggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .masthead {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #0a0a0a;
    width: 100%;
  }

  .masthead__inner {
    display: flex;
    align-items: center;
    height: 60px;
    padding: 0 60px;
    gap: 24px;
  }

  .masthead__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .masthead__wordmark {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: #f5f5f0;
    white-space: nowrap;
  }

  .masthead__nav {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-left: auto;
  }

  .masthead__nav a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: #f5f5f0;
    text-decoration: none;
    transition: color 0.15s;
  }

  .masthead__nav a:hover {
    color: #ff4d2e;
  }

  .masthead__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 24px;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: #f5f5f0;
    line-height: 1;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .theme-toggle:hover {
    color: #ff4d2e;
  }

  .theme-toggle__icon {
    display: flex;
    align-items: center;
  }

  .theme-toggle__icon--dark {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle__icon--light {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle__icon--dark {
    display: flex;
  }

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #f5f5f0;
    transition: color 0.15s;
  }

  .nav-toggle:hover {
    color: #ff4d2e;
  }

  .masthead__mobile-nav {
    display: flex;
    flex-direction: column;
    background: #0a0a0a;
    border-top: 1px solid #222;
    padding: 0 24px;
    gap: 16px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-in-out, padding 0.3s ease-in-out;
  }

  .masthead__mobile-nav.nav-open {
    max-height: 500px;
    padding: 16px 24px;
  }

  .masthead__mobile-nav a {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: #f5f5f0;
    text-decoration: none;
  }

  .masthead__mobile-nav a:hover {
    color: #ff4d2e;
  }

  /* Tablet (640–1023px) */
  @media (min-width: 640px) and (max-width: 1023px) {
    .masthead__inner {
      padding: 0 40px;
    }

    .masthead__nav a {
      font-size: 11px;
    }
  }

  /* Mobile (≤639px) */
  @media (max-width: 639px) {
    .masthead__inner {
      padding: 0 24px;
    }

    .masthead__nav {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .masthead__wordmark {
      font-size: 11px;
    }

    .masthead__mobile-nav a {
      min-height: 48px;
      display: flex;
      align-items: center;
    }
  }
</style>
