---
interface Props {
  title: string;
  description: string;
  category: string;
  date: Date;
  slug: string;
}

const { title, description, category, date, slug } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).toUpperCase();
---

<article class="post-card">
  <div class="post-card__accent-bar"></div>
  <div class="post-card__body">
    <div class="post-card__meta">
      <span class="post-card__category">{category.toUpperCase()}</span>
      <span class="post-card__date">{formatted}</span>
    </div>
    <h3 class="post-card__title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    <p class="post-card__excerpt">{description}</p>
    <a href={`/blog/${slug}`} class="post-card__read">READ &rarr;</a>
  </div>
</article>

<style>
  .post-card {
    background: var(--color-bg);
    border: 1px solid var(--color-ink);
    /* Desktop: left border overlaps the previous card's right border */
    margin-left: -1px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .post-card {
      margin-left: 0;
      margin-top: -1px;
    }
  }

  .post-card__accent-bar {
    height: 8px;
    background: var(--color-ink);
    flex-shrink: 0;
  }

  .post-card__body {
    padding: 27px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0;
  }

  .post-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 20px;
  }

  .post-card__category {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-orange);
  }

  .post-card__date {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: var(--color-muted);
  }

  .post-card__title {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 16px;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--color-ink);
  }

  .post-card__excerpt {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-ink);
    flex: 1;
    margin-bottom: 32px;
  }

  .post-card__read {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-ink);
    text-decoration: none;
    margin-top: auto;
  }

  .post-card__read:hover {
    color: var(--color-orange);
  }
</style>
